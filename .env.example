# Local demo environment — do not put real secrets here.
# Generate ignored credentials with: bash scripts/create_demo_env.sh

# Path to generated bearer-token map (preferred for local demo)
DECISION_ENGINE_AUTH_TOKENS_FILE=./auth.tokens.local.json

# Smoke test helpers (written by create_demo_env.sh)
SMOKE_SAMPLE_TOKEN=
SMOKE_OTHER_TOKEN=
SMOKE_ADMIN_TOKEN=

# Database — generated by create_demo_env.sh (POSTGRES_PASSWORD must match DB_PASSWORD)
DB_HOST=postgres
DB_PORT=5432
DB_NAME=risk_engine_db
DB_USER=postgres
DB_PASSWORD=
POSTGRES_PASSWORD=
